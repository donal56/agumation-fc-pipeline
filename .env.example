# Copy this file to .env.local and fill your values.
OPENAI_API_KEY=your_openai_api_key
# Optional:
# OPENAI_MODEL=gpt-4.1-mini
# Transcribe cue splitting (set to 0 to disable):
# SRT_MAX_CUE_SECONDS=3.0
# SRT_MAX_CUE_CHARS=0
# Context sent to OpenAI for every request (helps with pronouns/tone):
# OPENAI_CONTEXT=The narrator is a woman.
# Optional per language-pair overrides:
# OPENAI_CONTEXT_JA_EN=The narrator is a woman.
# OPENAI_CONTEXT_EN_ES=The narrator is a woman.
